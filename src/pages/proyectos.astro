---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import SectionHead from '../components/SectionHead.astro';
import ProjectCard from '../components/ProjectCard.astro';

const all = await getCollection('proyectos');
const destacados = all.filter((p) => p.data.status !== 'archivado');
const archivo = all.filter((p) => p.data.status === 'archivado');
---

<PageLayout
  title="Proyectos · Sigma Data Club"
  eyebrow="/ proyectos"
  heading="Código abierto.<br>Todo en GitHub. <span class='accent'>MIT.</span>"
  lead={`Todo lo que sale del club vive en <a href="https://github.com/sigma-data-club">github.com/sigma-data-club</a>. Cada proyecto tiene un README con instrucciones reproducibles, dataset versionado y al menos un test que valida el pipeline.`}
>
  <section>
    <div class="container">
      <SectionHead eyebrow="Destacados" title="En curso ahora." num="01 / 03" />
      <div class="grid" style="gap: 1.25rem;">
        {destacados.map((p) => <ProjectCard project={p} />)}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <SectionHead eyebrow="Archivo" title="Cosas terminadas o congeladas." num="02 / 03" />
      <div class="grid" style="gap: 1.25rem;">
        {archivo.map((p) => <ProjectCard project={p} />)}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <SectionHead eyebrow="Propuestas" title="Del board al repo." num="03 / 03" />
      <div class="grid grid-3">
        <article class="card bracketed">
          <div class="card-meta"><span class="tag">// 01</span></div>
          <h3>Habla con el board</h3>
          <p>
            Acércate a cualquier miembro de la junta — en sesión, por Discord o por mail — con
            pregunta, dataset, hipótesis y esfuerzo estimado. Te respondemos en la misma semana.
          </p>
        </article>
        <article class="card bracketed">
          <div class="card-meta"><span class="tag">// 02</span></div>
          <h3>Defiéndelo en sesión</h3>
          <p>
            5 minutos en cualquier jueves: por qué importa, qué vas a medir y qué necesitas. Si
            dos socios se apuntan a colaborar, la junta lo aprueba en el acto.
          </p>
        </article>
        <article class="card bracketed">
          <div class="card-meta"><span class="tag">// 03</span></div>
          <h3>Pónlo en marcha</h3>
          <p>
            Abrimos repo bajo MIT, defines milestones y kick-off. README con setup reproducible,
            dataset versionado y al menos un test antes del primer merge a <code>main</code>.
          </p>
        </article>
      </div>
    </div>
  </section>
</PageLayout>
