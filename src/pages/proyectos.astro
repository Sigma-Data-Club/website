---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import SectionHead from '../components/SectionHead.astro';
import ProjectCard from '../components/ProjectCard.astro';

const all = await getCollection('proyectos');
const destacados = all.filter((p) => p.data.status !== 'archivado');
const archivo = all.filter((p) => p.data.status === 'archivado');
---

<PageLayout
  title="Proyectos · Sigma Data Club"
  eyebrow="/ proyectos"
  heading="31 repos.<br>Open source. <span class='accent'>MIT.</span>"
  lead={`Todo lo que sale del club vive en <a href="https://github.com/sigma-data-club">github.com/sigma-data-club</a>. Cada proyecto tiene un README con instrucciones reproducibles, dataset versionado y al menos un test que valida el pipeline.`}
>
  <section>
    <div class="container">
      <SectionHead eyebrow="Destacados" title="En curso ahora." num="01 / 03" />
      <div class="grid" style="gap: 1.25rem;">
        {destacados.map((p) => <ProjectCard project={p} />)}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <SectionHead eyebrow="Archivo" title="Cosas terminadas o congeladas." num="02 / 03" />
      <div class="grid" style="gap: 1.25rem;">
        {archivo.map((p) => <ProjectCard project={p} />)}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <SectionHead eyebrow="Cómo proponer un proyecto" title="Tres pasos." num="03 / 03" />
      <div class="grid grid-3">
        <article class="card bracketed">
          <div class="card-meta"><span class="tag">// 01</span></div>
          <h3>Abre un issue</h3>
          <p>
            En el monorepo <code>sigma-data-club/.proposals</code>. Plantilla incluida: pregunta,
            dataset, hipótesis, esfuerzo estimado.
          </p>
        </article>
        <article class="card bracketed">
          <div class="card-meta"><span class="tag">// 02</span></div>
          <h3>Defiéndelo en una sesión</h3>
          <p>
            5 minutos en cualquier jueves. Si dos socios se apuntan a colaborar, el track lead lo
            aprueba y abrimos repo.
          </p>
        </article>
        <article class="card bracketed">
          <div class="card-meta"><span class="tag">// 03</span></div>
          <h3>Publica</h3>
          <p>
            README con setup reproducible, dataset versionado en DVC, al menos un test. Cuando
            merguemos a <code>main</code>, lo anunciamos en la newsletter.
          </p>
        </article>
      </div>
    </div>
  </section>
</PageLayout>
