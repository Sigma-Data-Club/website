---
import type { CollectionEntry } from 'astro:content';
interface Props {
  project: CollectionEntry<'proyectos'>;
}
const { project } = Astro.props;
const { title, thumb, status, category, summary, contribCount, tags, repoUrl } = project.data;
const categoryLower = category.toLowerCase();
const contribLabel =
  contribCount === undefined ? null : `${contribCount} contrib${contribCount === 1 ? '' : 's'}`;
const Tag = repoUrl ? 'a' : 'article';
const linkProps = repoUrl
  ? { href: repoUrl, target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

<Tag class:list={['project', { 'project-link': !!repoUrl }]} {...linkProps}>
  <div class="thumb">{thumb}</div>
  <div>
    <div class="meta">
      {status} · {categoryLower}{contribLabel && ` · ${contribLabel}`}
    </div>
    <h3>{title}</h3>
    <p>{summary}</p>
    {
      tags.length > 0 && (
        <div class="tags">
          {tags.map((t) => (
            <span>{t}</span>
          ))}
        </div>
      )
    }
  </div>
  {repoUrl && <span class="project-cta" aria-hidden="true">repo →</span>}
</Tag>
