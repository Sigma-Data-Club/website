---
import type { CollectionEntry } from 'astro:content';
interface Props {
  person: CollectionEntry<'equipo'>;
}
const { person } = Astro.props;
const { name, role, bio, url, linkedin, github } = person.data;
const link = url ?? linkedin ?? github;
const Tag = link ? 'a' : 'article';
const linkProps = link
  ? { href: link, target: '_blank', rel: 'noopener noreferrer', 'aria-label': `Abrir perfil de ${name}` }
  : {};
---

<Tag class="person" {...linkProps}>
  <div>
    <div class="name">{name}</div>
    <div class="role">{role}</div>
  </div>
  <div class="bio">{bio}</div>
</Tag>
