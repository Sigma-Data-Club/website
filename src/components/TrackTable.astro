---
import type { CollectionEntry } from 'astro:content';
interface Props {
  tracks: CollectionEntry<'tracks'>[];
}
const { tracks } = Astro.props;

const pillClass = (s: string) =>
  s === 'activo' ? 'pill' : s === 'en formación' ? 'pill warn' : 'pill dim';
---

<table class="tbl">
  <thead>
    <tr>
      <th>track</th>
      <th>lead</th>
      <th>grado / programa</th>
      <th>foco 2025/26</th>
      <th>estado</th>
    </tr>
  </thead>
  <tbody>
    {
      tracks.map((t) => (
        <tr>
          <td>
            <strong>{t.data.name}</strong>
          </td>
          <td>{t.data.lead}</td>
          <td>{t.data.program}</td>
          <td>{t.data.focus}</td>
          <td>
            <span class={pillClass(t.data.status)}>{t.data.status}</span>
          </td>
        </tr>
      ))
    }
  </tbody>
</table>
